# OpenTelemetry / Phoenix tracing — enables full-depth LLM + agent loop tracing.
# See docs/architecture.md for details on the tracing subsystem.
IMPRINT_TRACE=1
IMPRINT_TRACE_BATCH=false
IMPRINT_TRACE_LLM_IO=1
IMPRINT_TRACE_TOOL_IO=1
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006

# Claude via Vertex AI for session analysis + codegen.
# Uses Google Application Default Credentials (ADC) — no API key needed.
# Make sure you've run: gcloud auth application-default login
# And that the project has Vertex AI API + Anthropic Claude models enabled.
CLOUD_ML_REGION=us-east5
ANTHROPIC_VERTEX_PROJECT_ID=
# Vertex model IDs use hyphens, not @-suffixes:
ANTHROPIC_MODEL=claude-sonnet-4-6@20260301

# `imprint cron` failure notifications. Pick either provider (or both —
# they fire in parallel). With nothing configured, failures just log
# to stderr.

# --- Pushover (paid app, $5 one-time per platform; iOS + Android + desktop)
# https://pushover.net/  — app token at https://pushover.net/apps/build
PUSHOVER_TOKEN=
PUSHOVER_USER=

# --- ntfy (free, self-hostable; just pick a hard-to-guess topic name)
# https://ntfy.sh/  — for self-hosted, point NTFY_URL at your server.
# NTFY_TOKEN is only needed for protected topics on a private instance.
NTFY_URL=
NTFY_TOKEN=

# Optional: override the chromium executable path
# CHROMIUM_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Per-demo session cookies (paste from devtools, format depends on site)
# CANTEEN_SESSION_COOKIE=
